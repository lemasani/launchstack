{
  "name": "create-react-starter",
  "version": "0.0.1",
  "description": "Scaffold a React + Vite + TypeScript starter with optional libraries",
  "type": "module",
  "author": "lemasani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemasani/react-starter-template.git",
    "directory": "packages/create-react-starter"
  },
  "bugs": {
    "url": "https://github.com/lemasani/react-starter-template/issues"
  },
  "homepage": "https://github.com/lemasani/react-starter-template/tree/main/packages/create-react-starter#readme",
  "bin": {
    "create-react-starter": "./dist/index.js"
  },
  "files": [
    "dist",
    "template",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "starter",
    "template",
    "cli",
    "scaffold",
    "react-router",
    "tanstack",
    "tailwind",
    "shadcn-ui",
    "create-app"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^13.0.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "@vitest/ui": "^4.0.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
